# Docker Environment Configuration
# Copy this file to .env.docker and update with your values.
# Values under `env_file` are loaded into the backend container.
# Values used by docker-compose itself (interpolation) must also be in
# `.env` at the repo root — docker-compose reads that automatically.

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-in-production

# Set to False for production
DJANGO_DEBUG=False

# Public hostnames / IPs that reach this deployment
# Example: leave.example.com,10.10.73.5
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# CORS / CSRF
# ============================================================================
# When the SPA is served by nginx on the same origin as the API, CORS is
# effectively unused — but leave one entry for local dev.
CORS_ALLOWED_ORIGINS=http://localhost:8080

# Extra CSRF trusted origins (comma-separated). Needed for HTTPS on non-default
# ports — ALLOWED_HOSTS alone produces `https://IP` which doesn't match `:8443`.
# Example: CSRF_TRUSTED_ORIGINS_EXTRA=https://10.10.11.246:8443
CSRF_TRUSTED_ORIGINS_EXTRA=

# ============================================================================
# DATABASE (also required at repo root .env for compose interpolation)
# ============================================================================
POSTGRES_DB=leave_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# ============================================================================
# FRONTEND BUILD-TIME CONFIG (used by docker-compose, not Django)
# ============================================================================
# Leave empty → frontend uses same-origin requests via the nginx reverse proxy.
# Set to a full URL only if the API is hosted elsewhere (e.g. https://api.example.com)
VITE_API_URL=

# Host port that exposes the production nginx (frontend + proxied API)
FRONTEND_PORT=8080
HTTPS_PORT=8443

# ============================================================================
# GOOGLE OAUTH
# ============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ============================================================================
# USER IMPORT SETTINGS
# ============================================================================
# Default password for bulk-imported users; they must change on first login.
DEFAULT_IMPORT_PASSWORD=
